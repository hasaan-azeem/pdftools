# Site URL (set this in Vercel environment variables)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# PDF Processing API (add your backend API URL when ready)
# PDF_API_URL=https://your-pdf-api.com
# PDF_API_KEY=your-api-key-here

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# File upload limits
NEXT_PUBLIC_MAX_FILE_SIZE_MB=100

# Backend API (your Render service URL)
# NEXT_PUBLIC_API_URL=https://pdftools-api.onrender.com

# pdftools-frontend folder mein yeh file banao
NEXT_PUBLIC_API_URL=http://localhost:4000